# Bero deployment example
#
# This variant is designed for a host that already runs:
# - OpenResty/Nginx on 80/443
# - local embedding service on the HOST (not inside this compose stack)
#
# docker-compose.yml supports host bind IP overrides:
# - FRONTEND_BIND_IP controls host port 13080
# - BACKEND_BIND_IP controls host port 18000
#
# Recommended on bero:
# - frontend -> Tailscale IP (for upstream reverse proxy from another node)
# - backend  -> 127.0.0.1 only
#
# The backend container reaches the host embedding service via the host Tailscale IP.
# On bero this is currently 100.84.168.72.

FRONTEND_BIND_IP=100.84.168.72
BACKEND_BIND_IP=127.0.0.1

# LLM (required)
API_BASE=https://sub2api-core.sinpo.xyz:8443/v1
API_KEY=replace-with-your-sub2api-key
MODEL=gpt-5.4
TEMPERATURE=0.7

# Embedding (required)
EMBEDDING_BACKEND=api
EMBEDDING_API_BASE=http://100.84.168.72:18095/v1
EMBEDDING_API_KEY=replace-with-the-bge-m3-bearer-token
EMBEDDING_API_MODEL=BAAI/bge-m3

# Auth
JWT_SECRET=change-me-in-production
DEFAULT_EMAIL=admin@techspar.local
DEFAULT_PASSWORD=admin123
DEFAULT_NAME=admin
ALLOW_REGISTRATION=false

# Optional Copilot / ASR / search
COPILOT_API_BASE=
COPILOT_API_KEY=
COPILOT_MODEL=
DASHSCOPE_API_KEY=
TAVILY_API_KEY=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_VPR_APP_ID=

# Optional long-audio review via OSS
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# Interview tuning
MAX_QUESTIONS_PER_PHASE=5
MAX_DRILL_QUESTIONS=15
